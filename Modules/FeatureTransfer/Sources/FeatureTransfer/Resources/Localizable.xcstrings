    "history.clearAllMessage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This removes the recent transfer list from this device."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيؤدي هذا إلى إزالة قائمة عمليات النقل الأخيرة من هذا الجهاز."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ini menghapus daftar transfer terbaru dari perangkat ini."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اس سے اس آلے کی حالیہ منتقلیوں کی فہرست حذف ہو جائے گی۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এটি এই ডিভাইস থেকে সাম্প্রতিক স্থানান্তর তালিকা সরিয়ে দেয়৷"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह इस डिवाइस से हालिया स्थानांतरण सूची को हटा देता है।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, son aktarım listesini bu cihazdan kaldırır."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cela supprime la liste des transferts récents de cet appareil."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "При этом список последних передач будет удален с этого устройства."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "بۇ بۇ ئۈسكۈنىدىن يېقىنقى يۆتكىلىش تىزىملىكىنى ئۆچۈرۈۋېتىدۇ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将从该设备中删除最近的传输列表。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina la lista de transferencias recientes de este dispositivo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso remove a lista de transferências recentes deste dispositivo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch wird die aktuelle Übertragungsliste von diesem Gerät entfernt."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thao tác này sẽ xóa danh sách chuyển gần đây khỏi thiết bị này."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이렇게 하면 이 기기에서 최근 전송 목록이 삭제됩니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
