    "settings.autoAcceptFavoritesHelp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatically accepts transfers only from trusted favorite devices."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يقبل عمليات النقل تلقائيًا من الأجهزة المفضلة الموثوقة فقط."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Secara otomatis menerima transfer hanya dari perangkat favorit tepercaya."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "صرف قابلِ اعتماد پسندیدہ آلات سے منتقلیاں خودکار طور پر قبول کرتا ہے۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "শুধুমাত্র বিশ্বস্ত প্রিয় ডিভাইস থেকে স্বয়ংক্রিয়ভাবে স্থানান্তর গ্রহণ করে।"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "केवल विश्वसनीय पसंदीदा डिवाइस से स्थानांतरण स्वचालित रूप से स्वीकार करता है।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yalnızca güvenilen favori cihazlardan yapılan aktarımları otomatik olarak kabul eder."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accepte automatiquement les transferts uniquement à partir d'appareils favoris de confiance."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Автоматически принимает переводы только с доверенных любимых устройств."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
