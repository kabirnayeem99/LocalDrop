    "settings.incomingPINHint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use a 6-digit PIN for nearby senders."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم رمز PIN مكوّنًا من 6 أرقام للمرسلين القريبين."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan PIN 6 digit untuk pengirim terdekat."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "قریبی بھیجنے والوں کے لیے 6 ہندسوں کا PIN استعمال کریں۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "কাছাকাছি প্রেরকদের জন্য একটি 6-সংখ্যার পিন ব্যবহার করুন৷"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आस-पास के प्रेषकों के लिए 6-अंकीय पिन का उपयोग करें।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yakındaki gönderenler için 6 haneli bir PIN kullanın."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez un code PIN à 6 chiffres pour les expéditeurs à proximité."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используйте 6-значный PIN-код для ближайших отправителей."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "يېقىن ئەتراپتىكى ئەۋەتكۈچىلەر ئۈچۈن 6 خانىلىق PIN ئىشلىتىڭ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对附近的发件人使用 6 位 PIN 码。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilice un PIN de 6 dígitos para remitentes cercanos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use um PIN de 6 dígitos para remetentes próximos."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie für Absender in der Nähe eine 6-stellige PIN."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sử dụng mã PIN gồm 6 chữ số cho người gửi ở gần."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "근처에 있는 발신자에게는 6자리 PIN을 사용하세요."
