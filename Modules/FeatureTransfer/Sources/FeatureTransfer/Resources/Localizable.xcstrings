    "settings.useHTTPSHelp" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "شفّر حركة النقل باستخدام HTTPS. عطّل هذا الخيار لاستخدام HTTP غير المشفر على الشبكة المحلية."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTPS দিয়ে ট্রাফিক ট্রাফিক এনক্রিপ্ট করুন। স্থানীয় নেটওয়ার্কে সাধারণ HTTP ব্যবহার করতে এটি বন্ধ করুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verschlüsseln Sie den Übertragungsverkehr mit HTTPS. Deaktivieren Sie diese Option, um im lokalen Netzwerk einfaches HTTP zu verwenden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Encrypt transfer traffic with HTTPS. Turn this off to use plain HTTP on the local network."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cifre el tráfico de transferencia con HTTPS. Desactive esta opción para utilizar HTTP simple en la red local."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chiffrez le trafic de transfert avec HTTPS. Désactivez cette option pour utiliser HTTP simple sur le réseau local."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTPS के साथ ट्रांसफर ट्रैफ़िक को एन्क्रिप्ट करें। स्थानीय नेटवर्क पर सादे HTTP का उपयोग करने के लिए इसे बंद करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enkripsi lalu lintas transfer dengan HTTPS. Nonaktifkan untuk menggunakan HTTP biasa di jaringan lokal."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTPS を使用して転送トラフィックを暗号化します。ローカル ネットワーク上でプレーン HTTP を使用するには、これをオフにします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTPS로 전송 트래픽을 암호화합니다. 로컬 네트워크에서 일반 HTTP를 사용하려면 이 옵션을 끄세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Criptografe o tráfego de transferência com HTTPS. Desative esta opção para usar HTTP simples na rede local."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Шифрование передаваемого трафика с помощью HTTPS. Отключите этот параметр, чтобы использовать обычный HTTP в локальной сети."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktarım trafiğini HTTPS ile şifreleyin. Yerel ağda düz HTTP kullanmak için bunu kapatın."
          }
        },
        "ug" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HTTPS ئارقىلىق يۆتكىلىش ئېقىمىنى مەخپىيلەشتۈرۈڭ. يەرلىك توردىكى ئاددىي HTTP نى ئىشلىتىش ئۈچۈن ئۇنى ئېتىڭ."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "منتقلی کی ٹریفک کو HTTPS سے خفیہ کریں۔ مقامی نیٹ ورک پر سادہ HTTP استعمال کرنے کے لیے اسے بند کریں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mã hóa lưu lượng truyền bằng HTTPS. Tắt tính năng này để sử dụng HTTP đơn giản trên mạng cục bộ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用 HTTPS 加密传输流量。关闭此选项可在本地网络上使用纯 HTTP。"
          }
        }
      }
    },
