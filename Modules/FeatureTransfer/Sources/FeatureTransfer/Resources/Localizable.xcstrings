    "send.noDevicesHelp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Refresh discovery or keep this screen open while another device starts LocalDrop."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حدّث الاكتشاف أو أبقِ هذه الشاشة مفتوحة أثناء تشغيل LocalDrop على جهاز آخر."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Segarkan pencarian atau biarkan layar ini terbuka saat perangkat lain memulai LocalDrop."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "دریافت تازہ کریں یا یہ اسکرین کھلی رکھیں جب دوسرا آلہ LocalDrop شروع کرے۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আবিষ্কার রিফ্রেশ করুন বা অন্য ডিভাইস LocalDrop শুরু করার সময় এই স্ক্রীনটি খোলা রাখুন।"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "डिस्कवरी को रिफ्रेश करें या इस स्क्रीन को तब तक खुला रखें जब तक कोई अन्य डिवाइस लोकलड्रॉप शुरू न कर दे।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Keşfi yenileyin veya başka bir cihaz LocalDrop'u başlatırken bu ekranı açık tutun."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualisez la découverte ou laissez cet écran ouvert pendant qu'un autre appareil démarre LocalDrop."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обновите обнаружение или оставьте этот экран открытым, пока другое устройство запускает LocalDrop."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "باشقا ئۈسكۈنىلەر LocalDrop قوزغالغاندا بايقاشنى يېڭىلاڭ ياكى بۇ ئېكراننى ئوچۇق قىلىڭ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "刷新发现或在另一台设备启动 LocalDrop 时保持此屏幕打开。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actualice el descubrimiento o mantenga esta pantalla abierta mientras otro dispositivo inicia LocalDrop."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Atualize a descoberta ou mantenha esta tela aberta enquanto outro dispositivo inicia o LocalDrop."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktualisieren Sie die Erkennung oder lassen Sie diesen Bildschirm geöffnet, während ein anderes Gerät LocalDrop startet."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Làm mới khám phá hoặc giữ màn hình này mở trong khi thiết bị khác khởi động LocalDrop."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "검색을 새로 고치거나 다른 장치가 LocalDrop을 시작하는 동안 이 화면을 열어 두세요."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検出を更新するか、別のデバイスが LocalDrop を開始している間、この画面を開いたままにします。"
          }
        }
      }
    },
    "send.refreshingDevices": {
