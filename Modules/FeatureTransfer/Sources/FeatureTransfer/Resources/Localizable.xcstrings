    "send.mode.singleDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Single recipient sends the current staged items to one device in the foreground."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يرسل المستلم الواحد العناصر المجهّزة إلى جهاز واحد في المقدمة."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Satu penerima mengirim item yang sedang disiapkan ke satu perangkat di latar depan."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ایک وصول کنندہ موجودہ تیار شدہ آئٹمز کو پیش منظر میں ایک آلے تک بھیجتا ہے۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "একক প্রাপক বর্তমান মঞ্চস্থ আইটেমগুলিকে অগ্রভাগে একটি ডিভাইসে পাঠায়।"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एकल प्राप्तकर्ता वर्तमान चरणबद्ध आइटम को अग्रभूमि में एक डिवाइस पर भेजता है।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tek alıcı, geçerli olarak hazırlanmış öğeleri ön plandaki bir cihaza gönderir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un destinataire unique envoie les éléments actuellement préparés à un appareil au premier plan."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Один получатель отправляет текущие подготовленные элементы на одно устройство на переднем плане."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "يەككە تاپشۇرۇۋالغۇچى نۆۋەتتىكى سەھنىدىكى نەرسىلەرنى ئالدىنقى ئورۇنغا بىر ئۈسكۈنىگە ئەۋەتىدۇ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "单个收件人将当前暂存的项目发送到前台的一台设备。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un único destinatario envía los elementos preparados actualmente a un dispositivo en primer plano."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um único destinatário envia os itens atualmente preparados para um dispositivo em primeiro plano."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein einzelner Empfänger sendet die aktuell bereitgestellten Elemente an ein Gerät im Vordergrund."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Người nhận duy nhất sẽ gửi các mục theo giai đoạn hiện tại tới một thiết bị ở nền trước."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "단일 수신자는 현재 준비된 항목을 포그라운드에 있는 하나의 장치로 보냅니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "単一の受信者が、現在ステージングされているアイテムをフォアグラウンドの 1 つのデバイスに送信します。"
          }
        }
      }
    },
