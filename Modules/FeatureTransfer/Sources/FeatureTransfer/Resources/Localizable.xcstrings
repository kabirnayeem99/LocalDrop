    "send.refreshingDevicesHelp" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتم تحديث الاكتشاف حتى تظهر الأجهزة الجديدة دون تغيير مفاجئ في الحالة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আবিষ্কারটি রিফ্রেশ করছে তাই নতুন সহকর্মীরা হার্ড স্টেট জাম্প ছাড়াই উপস্থিত হতে পারে।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Discovery ist erfrischend, sodass neue Kollegen ohne einen harten Statussprung erscheinen können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Discovery is refreshing so new peers can appear without a hard state jump."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El descubrimiento es refrescante, por lo que pueden aparecer nuevos pares sin un salto de estado brusco."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La découverte est rafraîchissante, car de nouveaux pairs peuvent apparaître sans un saut d'état brutal."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "खोज ताज़ा है इसलिए नए साथी बिना किसी कठिन स्थिति के सामने आ सकते हैं।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pencarian sedang diperbarui agar perangkat baru muncul tanpa perubahan status mendadak."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Discovery はリフレッシュされるため、ハードな状態ジャンプを行わずに新しいピアを表示できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "검색이 새로워져 하드 상태 점프 없이 새로운 피어가 나타날 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A descoberta é refrescante para que novos pares possam aparecer sem um grande salto de estado."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Discovery обновляется, поэтому новые узлы могут появляться без жесткого перехода."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keşif yenileniyor, böylece yeni akranlar zor durum atlaması olmadan ortaya çıkabilir."
          }
        },
        "ug" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بايقاش كىشىنى روھلاندۇرىدۇ ، شۇڭا يېڭى تورداشلار قاتتىق سەكرىمەيلا پەيدا بولىدۇ."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "دریافت تازہ ہو رہی ہے تاکہ نئے آلات اچانک حالت بدلے بغیر ظاہر ہوں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tính năng khám phá được làm mới để các đồng nghiệp mới có thể xuất hiện mà không cần chuyển trạng thái khó khăn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "发现令人耳目一新，因此新的对等点无需硬状态跳转即可出现。"
          }
        }
      }
    },
