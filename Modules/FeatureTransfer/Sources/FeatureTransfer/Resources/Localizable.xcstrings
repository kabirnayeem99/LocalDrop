    "sendText.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop saves this text as a temporary .txt file before sending it."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحفظ LocalDrop هذا النص كملف ‎.txt مؤقت قبل إرساله."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop menyimpan teks ini sebagai file .txt sementara sebelum mengirimnya."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop اس متن کو بھیجنے سے پہلے عارضی .txt فائل کے طور پر محفوظ کرتا ہے۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "লোকালড্রপ এই পাঠ্যটিকে পাঠানোর আগে একটি অস্থায়ী .txt ফাইল হিসাবে সংরক্ষণ করে।"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लोकलड्रॉप इस टेक्स्ट को भेजने से पहले एक अस्थायी .txt फ़ाइल के रूप में सहेजता है।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop, bu metni göndermeden önce geçici bir .txt dosyası olarak kaydeder."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop enregistre ce texte sous forme de fichier .txt temporaire avant de l'envoyer."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop сохраняет этот текст как временный файл .txt перед его отправкой."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop بۇ تېكىستنى ئەۋەتىشتىن بۇرۇن ۋاقىتلىق .txt ھۆججىتى سۈپىتىدە ساقلايدۇ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop 在发送之前将此文本保存为临时 .txt 文件。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop guarda este texto como un archivo .txt temporal antes de enviarlo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop salva este texto como um arquivo .txt temporário antes de enviá-lo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop speichert diesen Text vor dem Senden als temporäre TXT-Datei."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop lưu văn bản này dưới dạng tệp .txt tạm thời trước khi gửi."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop은 이 텍스트를 보내기 전에 임시 .txt 파일로 저장합니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop は、このテキストを送信する前に一時的な .txt ファイルとして保存します。"
          }
        }
      }
    },
