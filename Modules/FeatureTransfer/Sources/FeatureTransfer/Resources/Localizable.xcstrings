    "send.mode.multipleDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Multiple recipients keeps sends open per device so you can target several nearby devices."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يبقي وضع عدة مستلمين جلسات الإرسال مفتوحة لكل جهاز حتى تتمكن من استهداف عدة أجهزة قريبة."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Beberapa penerima mempertahankan pengiriman per perangkat agar Anda dapat menargetkan beberapa perangkat terdekat."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "متعدد وصول کنندگان موڈ ہر آلے کے لیے بھیجنے کے سیشن کھلے رکھتا ہے تاکہ آپ کئی قریبی آلات کو ہدف بنا سکیں۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "একাধিক প্রাপক প্রতিটি ডিভাইসে পাঠান খোলা রাখে যাতে আপনি কাছাকাছি কয়েকটি ডিভাইসকে লক্ষ্য করতে পারেন।"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एकाधिक प्राप्तकर्ता प्रति डिवाइस पर भेजे गए संदेशों को खुला रखते हैं ताकि आप आस-पास के कई डिवाइसों को लक्षित कर सकें।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Birden fazla alıcı, gönderimleri cihaz başına açık tutar, böylece yakındaki birden fazla cihazı hedefleyebilirsiniz."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Plusieurs destinataires maintiennent les envois ouverts par appareil afin que vous puissiez cibler plusieurs appareils à proximité."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "При наличии нескольких получателей сообщения остаются открытыми для каждого устройства, поэтому вы можете настроить таргетинг на несколько близлежащих устройств."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "كۆپ قوبۇللىغۇچ ھەر بىر ئۈسكۈنىگە ئوچۇق ئەۋەتىدۇ ، شۇڭا سىز يېقىن ئەتراپتىكى بىر قانچە ئۈسكۈنىنى نىشانلىيالايسىز."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "多个收件人使每台设备的发送保持打开状态，以便您可以定位附近的多个设备。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Varios destinatarios mantienen los envíos abiertos por dispositivo para que puedas dirigirte a varios dispositivos cercanos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Vários destinatários mantêm os envios abertos por dispositivo para que você possa segmentar vários dispositivos próximos."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bei mehreren Empfängern bleiben die Versendungen pro Gerät offen, sodass Sie mehrere Geräte in der Nähe gezielt ansprechen können."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhiều người nhận tiếp tục gửi mở trên mỗi thiết bị để bạn có thể nhắm mục tiêu đến một số thiết bị lân cận."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여러 명의 수신자가 장치별로 전송을 열어두므로 근처에 있는 여러 장치를 대상으로 지정할 수 있습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "複数の受信者はデバイスごとに送信を開いたままにするため、近くにある複数のデバイスをターゲットにすることができます。"
          }
        }
      }
    },
