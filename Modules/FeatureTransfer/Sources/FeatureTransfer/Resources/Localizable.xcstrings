    "send.scanningDevicesHelp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop is actively scanning the network for nearby peers."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يبحث LocalDrop حاليًا في الشبكة عن أجهزة قريبة."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop sedang aktif memindai jaringan untuk perangkat terdekat."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop قریبی آلات کے لیے نیٹ ورک کو فعال طور پر اسکین کر رہا ہے۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop সক্রিয়ভাবে কাছাকাছি সহকর্মীদের জন্য নেটওয়ার্ক স্ক্যান করছে৷"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लोकलड्रॉप आस-पास के साथियों के लिए नेटवर्क को सक्रिय रूप से स्कैन कर रहा है।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop, yakındaki eşler için ağı aktif olarak tarıyor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop analyse activement le réseau à la recherche de pairs à proximité."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop активно сканирует сеть на наличие ближайших узлов."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop يېقىن ئەتراپتىكى تورداشلار ئۈچۈن تورنى ئاكتىپلىق بىلەن سايىلەيدۇ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop 正在主动扫描网络以查找附近的对等点。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop está escaneando activamente la red en busca de pares cercanos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop está verificando ativamente a rede em busca de pares próximos."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop durchsucht das Netzwerk aktiv nach Peers in der Nähe."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop đang tích cực quét mạng để tìm các đồng nghiệp ở gần."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop은 근처 피어를 찾기 위해 네트워크를 적극적으로 검색하고 있습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalDrop は、ネットワークをアクティブにスキャンして近くのピアを探します。"
          }
        }
      }
    },
