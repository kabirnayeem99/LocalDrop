    "app.about.tagline": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Native macOS file sharing for the LocalSend ecosystem"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مشاركة ملفات أصلية لنظام macOS ضمن منظومة LocalSend"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Berbagi file native macOS untuk ekosistem LocalSend"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalSend ایکو سسٹم کے لیے مقامی macOS فائل شیئرنگ"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "LocalSend ইকোসিস্টেমের জন্য নেটিভ macOS ফাইল শেয়ারিং"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लोकलसेंड इकोसिस्टम के लिए मूल macOS फ़ाइल साझाकरण"
          }
        },
        "tr": {
