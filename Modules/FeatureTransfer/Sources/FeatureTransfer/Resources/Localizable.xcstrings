            "value": "Dosyaları, klasörleri veya metni önce LocalDrop'ta hazırlayın"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Placez d'abord les fichiers, les dossiers ou le texte dans LocalDrop"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сначала загружайте файлы, папки или текст в LocalDrop."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
