    "settings.shareViaLinkAutoAccept": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Auto-accept share via link requests"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "القبول التلقائي لطلبات المشاركة عبر الرابط"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Terima otomatis permintaan bagikan lewat tautan"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "لنک شیئر کی درخواستوں کو خودکار طور پر قبول کریں"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "লিঙ্ক অনুরোধের মাধ্যমে শেয়ার স্বয়ংক্রিয়ভাবে গ্রহণ করুন"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लिंक अनुरोधों के माध्यम से शेयर को स्वतः स्वीकार करें"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bağlantı istekleri yoluyla paylaşımı otomatik olarak kabul et"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Accepter automatiquement le partage via les demandes de lien"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Автоматическое принятие общего доступа через запросы на ссылку"
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "ئۇلىنىش تەلىپى ئارقىلىق ئورتاقلىشىشنى ئاپتوماتىك قوبۇل قىلىڭ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过链接请求自动接受共享"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aceptar automáticamente compartir a través de solicitudes de enlace"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aceitar compartilhamento automaticamente por meio de solicitações de link"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Teilen über Linkanfragen automatisch akzeptieren"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tự động chấp nhận chia sẻ thông qua yêu cầu liên kết"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "링크 요청을 통해 공유 자동 수락"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リンクリクエストによる共有を自動的に受け入れる"
          }
        }
      }
    },
    "settings.shareViaLinkAutoAcceptHelp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accept incoming link-share downloads immediately when link sharing is active."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اقبل تنزيلات المشاركة عبر الرابط الواردة فورًا عند تفعيل المشاركة عبر الرابط."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Terima unduhan bagikan lewat tautan yang masuk segera saat berbagi tautan aktif."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "جب لنک شیئرنگ فعال ہو تو آنے والی لنک شیئر ڈاؤن لوڈز کو فوراً قبول کریں۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "লিঙ্ক শেয়ারিং সক্রিয় থাকা অবস্থায় অবিলম্বে ইনকামিং লিঙ্ক-শেয়ার ডাউনলোডগুলি গ্রহণ করুন।"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लिंक साझाकरण सक्रिय होने पर आने वाले लिंक-शेयर डाउनलोड को तुरंत स्वीकार करें।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bağlantı paylaşımı etkin olduğunda, gelen bağlantı paylaşımı indirmelerini hemen kabul edin."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Acceptez immédiatement les téléchargements de partage de lien entrants lorsque le partage de lien est actif."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Принимайте входящие загрузки по ссылке сразу же, когда общий доступ по ссылке активен."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "ئۇلىنىش ھەمبەھىرلىنىش ئاكتىپ بولغاندا كەلگەن ئۇلىنىش-ھەمبەھىر چۈشۈرۈشنى دەرھال قوبۇل قىلىڭ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当链接共享处于活动状态时，立即接受传入的链接共享下载。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acepte las descargas entrantes de enlaces compartidos inmediatamente cuando el enlace compartido esté activo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aceite downloads de compartilhamento de link recebidos imediatamente quando o compartilhamento de link estiver ativo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Akzeptieren Sie eingehende Link-Sharing-Downloads sofort, wenn die Link-Freigabe aktiv ist."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chấp nhận tải xuống chia sẻ liên kết đến ngay lập tức khi chia sẻ liên kết được kích hoạt."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "링크 공유가 활성화되면 수신 링크 공유 다운로드를 즉시 수락합니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リンク共有がアクティブな場合は、受信したリンク共有ダウンロードをすぐに受け入れます。"
          }
        }
      }
    },
