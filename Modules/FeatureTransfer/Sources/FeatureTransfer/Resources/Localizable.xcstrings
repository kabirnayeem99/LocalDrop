    "sendText.validationInfo": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your text will be staged as a plain-text file on the Send screen."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم تجهيز النص كملف نص عادي في شاشة الإرسال."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
