    "settings.requirePINHelp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adds a PIN check before accepting incoming transfers."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يضيف التحقق من رمز PIN قبل قبول عمليات النقل الواردة."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Menambahkan pemeriksaan PIN sebelum menerima transfer masuk."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "موصول ہونے والی منتقلی قبول کرنے سے پہلے PIN کی جانچ شامل کرتا ہے۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ইনকামিং ট্রান্সফার গ্রহণ করার আগে একটি পিন চেক যোগ করে।"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आने वाले स्थानांतरण स्वीकार करने से पहले एक पिन जांच जोड़ता है।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gelen transferleri kabul etmeden önce bir PIN kontrolü ekler."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoute une vérification du code PIN avant d'accepter les transferts entrants."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавляет проверку PIN-кода перед принятием входящих переводов."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "كەلگەن يۆتكىلىشنى قوبۇل قىلىشتىن بۇرۇن PIN تەكشۈرۈشى قوشىدۇ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在接受传入转账之前添加 PIN 检查。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrega una verificación de PIN antes de aceptar transferencias entrantes."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adiciona uma verificação de PIN antes de aceitar transferências recebidas."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügt eine PIN-Prüfung hinzu, bevor eingehende Überweisungen akzeptiert werden."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thêm kiểm tra mã PIN trước khi chấp nhận chuyển khoản đến."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "들어오는 전송을 수락하기 전에 PIN 확인을 추가합니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "受信転送を受け入れる前に PIN チェックを追加します。"
          }
        }
      }
    },
    "settings.requirePINMessage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Incoming transfers will require a PIN before files are accepted."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستتطلب عمليات النقل الواردة رمز PIN قبل قبول الملفات."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Transfer masuk akan memerlukan PIN sebelum file diterima."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "فائلیں قبول کرنے سے پہلے موصول ہونے والی منتقلیوں کے لیے PIN درکار ہوگا۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আগত স্থানান্তরগুলি ফাইলগুলি গ্রহণ করার আগে একটি পিনের প্রয়োজন হবে৷"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आने वाले ट्रांसफ़र के लिए फ़ाइलें स्वीकार करने से पहले एक पिन की आवश्यकता होगी।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gelen transferler, dosyalar kabul edilmeden önce bir PIN gerektirecektir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les transferts entrants nécessiteront un code PIN avant que les fichiers soient acceptés."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для входящих переводов потребуется PIN-код, прежде чем файлы будут приняты."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "كەلگەن يۆتكىلىش ھۆججەتلەر قوبۇل قىلىنىشتىن بۇرۇن PIN تەلەپ قىلىدۇ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "传入传输需要输入 PIN 码才能接受文件。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las transferencias entrantes requerirán un PIN antes de aceptar los archivos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As transferências recebidas exigirão um PIN antes que os arquivos sejam aceitos."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für eingehende Überweisungen ist eine PIN erforderlich, bevor Dateien akzeptiert werden."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chuyển khoản đến sẽ yêu cầu mã PIN trước khi tệp được chấp nhận."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Incoming transfers will require a PIN before files are accepted."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "受信転送では、ファイルが受け入れられる前に PIN が必要になります。"
          }
        }
      }
    },
