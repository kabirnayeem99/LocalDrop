    "incomingRequest.fileSelectionHint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose which files to accept from this transfer."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر الملفات التي تريد قبولها من عملية النقل هذه."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih file yang akan diterima dari transfer ini."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "منتخب کریں کہ اس منتقلی سے کون سی فائلیں قبول کرنی ہیں۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এই স্থানান্তর থেকে কোন ফাইলগুলি গ্রহণ করবেন তা চয়ন করুন৷"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "चुनें कि इस स्थानांतरण से कौन सी फ़ाइलें स्वीकार करनी हैं।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu aktarımdan hangi dosyaların kabul edileceğini seçin."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez les fichiers à accepter de ce transfert."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите, какие файлы принять из этой передачи."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "بۇ يۆتكىلىشتىن قايسى ھۆججەتلەرنى قوبۇل قىلىشنى تاللاڭ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择在此传输中接受哪些文件。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elija qué archivos aceptar de esta transferencia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha quais arquivos aceitar desta transferência."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie aus, welche Dateien von dieser Übertragung akzeptiert werden sollen."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chọn tệp nào sẽ chấp nhận từ quá trình chuyển này."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 전송에서 허용할 파일을 선택하세요."
          }
