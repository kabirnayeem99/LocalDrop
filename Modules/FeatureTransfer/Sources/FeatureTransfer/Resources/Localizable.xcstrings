    "send.mode.linkDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Share via link exposes the staged items over a temporary local link for browsers or remote devices."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُظهر المشاركة عبر الرابط العناصر المجهّزة عبر رابط محلي مؤقت للمتصفحات أو الأجهزة البعيدة."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Bagikan lewat tautan menampilkan item yang disiapkan melalui tautan lokal sementara untuk browser atau perangkat jarak jauh."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "لنک کے ذریعے شیئر تیار شدہ آئٹمز کو براؤزر یا دور کے آلات کے لیے عارضی مقامی لنک پر مہیا کرتا ہے۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "লিঙ্কের মাধ্যমে শেয়ার করা ব্রাউজার বা দূরবর্তী ডিভাইসগুলির জন্য একটি অস্থায়ী স্থানীয় লিঙ্কের মাধ্যমে মঞ্চস্থ আইটেমগুলিকে প্রকাশ করে৷"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लिंक के माध्यम से साझा करना ब्राउज़र या दूरस्थ उपकरणों के लिए एक अस्थायी स्थानीय लिंक पर चरणबद्ध आइटम को उजागर करता है।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bağlantı yoluyla paylaş, hazırlanan öğeleri tarayıcılar veya uzak cihazlar için geçici bir yerel bağlantı üzerinden gösterir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Partager via un lien expose les éléments mis en scène via un lien local temporaire pour les navigateurs ou les appareils distants."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Общий доступ по ссылке предоставляет подготовленные элементы по временной локальной ссылке для браузеров или удаленных устройств."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "ئۇلىنىش ئارقىلىق ھەمبەھىرلىنىش توركۆرگۈچ ياكى يىراقتىكى ئۈسكۈنىلەرنىڭ ۋاقىتلىق يەرلىك ئۇلىنىشى ئارقىلىق قويۇلغان تۈرلەرنى ئاشكارىلايدۇ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过链接共享通过浏览器或远程设备的临时本地链接公开暂存的项目。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Compartir mediante enlace expone los elementos preparados a través de un enlace local temporal para navegadores o dispositivos remotos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Compartilhar via link expõe os itens preparados em um link local temporário para navegadores ou dispositivos remotos."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durch die Freigabe per Link werden die bereitgestellten Elemente über einen temporären lokalen Link für Browser oder Remote-Geräte verfügbar gemacht."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chia sẻ qua liên kết hiển thị các mục được dàn dựng qua liên kết cục bộ tạm thời cho trình duyệt hoặc thiết bị từ xa."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "링크를 통한 공유는 브라우저 또는 원격 장치에 대한 임시 로컬 링크를 통해 준비된 항목을 노출합니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リンク経由の共有は、ブラウザーまたはリモート デバイスの一時的なローカル リンクを介してステージングされたアイテムを公開します。"
          }
        }
      }
    },
