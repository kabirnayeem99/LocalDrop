    "send.dropZoneLabel": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag files or folders anywhere to send"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسحب الملفات أو المجلدات إلى أي مكان لإرسالها"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Seret file atau folder ke mana saja untuk mengirim"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "بھیجنے کے لیے فائلیں یا فولڈرز کہیں بھی گھسیٹیں"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "পাঠাতে ফাইল বা ফোল্ডার টেনে আনুন কোথাও"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "भेजने के लिए फ़ाइलों या फ़ोल्डरों को कहीं भी खींचें"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dosyaları veya klasörleri göndermek için herhangi bir yere sürükleyin"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faites glisser des fichiers ou des dossiers n'importe où pour les envoyer"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перетащите файлы или папки в любое место для отправки"
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "ھۆججەت ياكى ھۆججەت قىسقۇچنى ئەۋەتمەكچى بولغان يەرگە سۆرەپ كىرىڭ"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将文件或文件夹拖到任意位置即可发送"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrastre archivos o carpetas a cualquier lugar para enviarlos"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Arraste arquivos ou pastas para qualquer lugar para enviar"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziehen Sie Dateien oder Ordner zum Senden an eine beliebige Stelle"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kéo tệp hoặc thư mục vào bất kỳ đâu để gửi"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "파일이나 폴더를 어디로든 드래그하여 보내세요."
          }
        },
        "ja": {
          "stringUnit": {
