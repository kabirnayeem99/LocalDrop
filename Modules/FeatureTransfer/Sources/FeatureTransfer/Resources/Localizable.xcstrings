    "settings.useHTTPS": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use HTTPS for transfers"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدام HTTPS لعمليات النقل"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Gunakan HTTPS untuk transfer"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "منتقلیوں کے لیے HTTPS استعمال کریں"
          }
        }
      }
    },
    "settings.useHTTPSHelp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Encrypt transfer traffic with HTTPS. Turn this off to use plain HTTP on the local network."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "شفّر حركة النقل باستخدام HTTPS. عطّل هذا الخيار لاستخدام HTTP غير المشفر على الشبكة المحلية."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Enkripsi lalu lintas transfer dengan HTTPS. Nonaktifkan untuk menggunakan HTTP biasa di jaringan lokal."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "منتقلی کی ٹریفک کو HTTPS سے خفیہ کریں۔ مقامی نیٹ ورک پر سادہ HTTP استعمال کرنے کے لیے اسے بند کریں۔"
          }
        }
      }
    },
