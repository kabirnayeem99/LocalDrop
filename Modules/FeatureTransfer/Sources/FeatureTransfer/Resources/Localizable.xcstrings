    "send.mode.help" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اختر ما إذا كان LocalDrop سيرسل إلى جهاز واحد أو عدة أجهزة أو سيبدأ المشاركة عبر الرابط."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "লোকালড্রপ একটি ডিভাইসে, একাধিক ডিভাইসে পাঠাবে নাকি লিঙ্ক শেয়ার করা শুরু করবে তা বেছে নিন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wählen Sie, ob LocalDrop an ein oder mehrere Geräte sendet oder die Linkfreigabe startet."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choose whether LocalDrop sends to one device, multiple devices, or starts link sharing."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elija si LocalDrop envía a un dispositivo, a varios dispositivos o comienza a compartir enlaces."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Choisissez si LocalDrop envoie vers un appareil, plusieurs appareils ou démarre le partage de lien."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "चुनें कि क्या लोकलड्रॉप एक डिवाइस, एकाधिक डिवाइस पर भेजता है, या लिंक साझा करना शुरू करता है।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pilih apakah LocalDrop mengirim ke satu perangkat, beberapa perangkat, atau memulai berbagi tautan."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LocalDrop が 1 つのデバイスに送信するか、複数のデバイスに送信するか、リンク共有を開始するかを選択します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LocalDrop이 하나의 장치, 여러 장치로 보낼지 아니면 링크 공유를 시작할지 선택합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Escolha se o LocalDrop envia para um dispositivo, vários dispositivos ou inicia o compartilhamento de link."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Выберите, будет ли LocalDrop отправлять данные на одно устройство, на несколько устройств или начинать обмен ссылками."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LocalDrop'un bir cihaza mı, birden fazla cihaza mı göndereceğini veya bağlantı paylaşımını başlatıp başlatmayacağını seçin."
          }
        },
        "ug" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LocalDrop نىڭ بىر ئۈسكۈنىگە ، كۆپ ئۈسكۈنىگە ئەۋەتىدىغانلىقىنى ياكى ئۇلىنىشتىن ئورتاقلىشىشنى باشلاڭ."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "منتخب کریں کہ LocalDrop ایک آلہ، کئی آلات یا لنک شیئرنگ شروع کرے۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chọn xem LocalDrop gửi tới một thiết bị, nhiều thiết bị hay bắt đầu chia sẻ liên kết."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "选择 LocalDrop 是发送到一台设备、多台设备，还是启动链接共享。"
          }
        }
      }
    },
