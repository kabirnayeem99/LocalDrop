    "history.noTransfersHelp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Completed and declined transfers will appear here."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستظهر هنا عمليات النقل المكتملة والمرفوضة."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Transfer yang selesai dan ditolak akan muncul di sini."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "مکمل اور مسترد شدہ منتقلیاں یہاں دکھائی دیں گی۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সম্পূর্ণ এবং প্রত্যাখ্যান করা স্থানান্তর এখানে প্রদর্শিত হবে।"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पूर्ण और अस्वीकृत स्थानांतरण यहां दिखाई देंगे।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tamamlanan ve reddedilen aktarımlar burada görünür."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les transferts terminés et refusés apparaîtront ici."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Здесь будут отображаться выполненные и отклоненные переводы."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "تاماملانغان ۋە رەت قىلىنغان يۆتكىلىشلەر بۇ يەردە كۆرۈنىدۇ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已完成和拒绝的转账将显示在此处。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las transferencias completadas y rechazadas aparecerán aquí."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As transferências concluídas e recusadas aparecerão aqui."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abgeschlossene und abgelehnte Überweisungen werden hier angezeigt."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chuyển khoản đã hoàn tất và bị từ chối sẽ xuất hiện ở đây."
