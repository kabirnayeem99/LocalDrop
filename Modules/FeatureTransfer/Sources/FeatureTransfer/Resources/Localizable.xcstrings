          }
        },
        "ug" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يەككە تاپشۇرۇۋالغۇچى نۆۋەتتىكى سەھنىدىكى نەرسىلەرنى ئالدىنقى ئورۇنغا بىر ئۈسكۈنىگە ئەۋەتىدۇ."
