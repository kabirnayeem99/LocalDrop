    "settings.allowDownloadsHelp": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allows peers to fetch files exposed by this device."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يسمح للأجهزة الأخرى بجلب الملفات التي يتيحها هذا الجهاز."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Memungkinkan perangkat lain mengambil file yang dibagikan oleh perangkat ini."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "دوسرے آلات کو اس آلے کی دستیاب فائلیں حاصل کرنے دیتا ہے۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সমবয়সীদের এই ডিভাইস দ্বারা উন্মুক্ত করা ফাইলগুলি আনার অনুমতি দেয়৷"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "साथियों को इस उपकरण द्वारा प्रदर्शित फ़ाइलें लाने की अनुमति देता है।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Eşlerin bu cihaz tarafından açığa çıkan dosyaları getirmesine izin verir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Permet aux pairs de récupérer les fichiers exposés par cet appareil."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Позволяет одноранговым узлам получать файлы, предоставляемые этим устройством."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "تورداشلارنىڭ بۇ ئۈسكۈنىدە ئاشكارلانغان ھۆججەتلەرنى ئېلىپ بېرىشىغا يول قويىدۇ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "允许对等方获取此设备公开的文件。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permite a los pares recuperar archivos expuestos por este dispositivo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Permite que os pares busquem arquivos expostos por este dispositivo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ermöglicht Peers, von diesem Gerät bereitgestellte Dateien abzurufen."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cho phép các đồng nghiệp tìm nạp các tệp do thiết bị này hiển thị."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "피어가 이 기기에서 노출된 파일을 가져올 수 있도록 허용합니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ピアがこのデバイスによって公開されたファイルをフェッチできるようにします。"
          }
        }
      }
    },
    "settings.allowDownloadsMessage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nearby devices may request files that this device exposes through the transfer runtime."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قد تطلب الأجهزة القريبة الملفات التي يتيحها هذا الجهاز عبر بيئة النقل."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Perangkat terdekat dapat meminta file yang dibagikan perangkat ini melalui runtime transfer."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "قریبی آلات ان فائلوں کی درخواست کر سکتے ہیں جو یہ آلہ منتقلی رن ٹائم کے ذریعے دستیاب کرتا ہے۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আশেপাশের ডিভাইসগুলি ফাইলগুলিকে অনুরোধ করতে পারে যা এই ডিভাইসটি স্থানান্তর রানটাইমের মাধ্যমে প্রকাশ করে৷"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आस-पास के डिवाइस उन फ़ाइलों का अनुरोध कर सकते हैं जिन्हें यह डिवाइस ट्रांसफर रनटाइम के माध्यम से प्रदर्शित करता है।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yakındaki cihazlar, aktarım çalışma zamanı aracılığıyla bu cihazın sunduğu dosyaları isteyebilir."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les appareils à proximité peuvent demander des fichiers que cet appareil expose via l'exécution du transfert."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Соседние устройства могут запрашивать файлы, которые это устройство предоставляет во время выполнения передачи."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "يېقىن ئەتراپتىكى ئۈسكۈنىلەر بۇ ئۈسكۈنىنىڭ يۆتكىلىش ۋاقتى ئارقىلىق ئاشكارىلىغان ھۆججەتلەرنى تەلەپ قىلىشى مۇمكىن."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "附近的设备可能会请求该设备通过传输运行时公开的文件。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los dispositivos cercanos pueden solicitar archivos que este dispositivo expone a través del tiempo de ejecución de transferencia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Dispositivos próximos podem solicitar arquivos que este dispositivo expõe durante o tempo de execução de transferência."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geräte in der Nähe fordern möglicherweise Dateien an, die dieses Gerät über die Übertragungslaufzeit bereitstellt."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các thiết bị ở gần có thể yêu cầu các tệp mà thiết bị này hiển thị trong thời gian truyền."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "주변 장치는 전송 런타임을 통해 이 장치가 노출하는 파일을 요청할 수 있습니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "近くのデバイスは、このデバイスが転送ランタイムを通じて公開するファイルを要求する場合があります。"
          }
        }
      }
    },
