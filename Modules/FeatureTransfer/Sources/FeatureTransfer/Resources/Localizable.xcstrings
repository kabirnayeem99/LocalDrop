    "settings.httpsDisabledMessage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Transfers on this device will use plain HTTP on the local network until HTTPS is turned back on."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستستخدم عمليات النقل على هذا الجهاز HTTP غير المشفر على الشبكة المحلية حتى إعادة تشغيل HTTPS."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Transfer pada perangkat ini akan menggunakan HTTP biasa di jaringan lokal hingga HTTPS diaktifkan kembali."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اس آلے پر منتقلیاں مقامی نیٹ ورک میں سادہ HTTP استعمال کریں گی جب تک HTTPS دوبارہ فعال نہ کیا جائے۔"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTPS আবার চালু না হওয়া পর্যন্ত এই ডিভাইসে স্থানান্তর স্থানীয় নেটওয়ার্কে প্লেইন HTTP ব্যবহার করবে।"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "HTTPS वापस चालू होने तक इस डिवाइस पर स्थानांतरण स्थानीय नेटवर्क पर सादे HTTP का उपयोग करेगा।"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu cihazdaki aktarımlar, HTTPS tekrar açılıncaya kadar yerel ağdaki düz HTTP'yi kullanacak."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les transferts sur cet appareil utiliseront le HTTP simple sur le réseau local jusqu'à ce que HTTPS soit réactivé."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Для передачи на этом устройстве будет использоваться обычный HTTP в локальной сети, пока HTTPS не будет снова включен."
          }
        },
        "ug": {
          "stringUnit": {
            "state": "translated",
            "value": "بۇ ئۈسكۈنىدىكى يۆتكىلىشچان HTTPS قايتا ئېچىلغۇچە يەرلىك توردىكى ئاددىي HTTP ئىشلىتىلىدۇ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此设备上的传输将使用本地网络上的纯 HTTP，直到重新打开 HTTPS。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las transferencias en este dispositivo utilizarán HTTP simple en la red local hasta que se vuelva a activar HTTPS."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As transferências neste dispositivo usarão HTTP simples na rede local até que o HTTPS seja reativado."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Übertragungen auf diesem Gerät verwenden einfaches HTTP im lokalen Netzwerk, bis HTTPS wieder aktiviert wird."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Quá trình truyền trên thiết bị này sẽ sử dụng HTTP đơn giản trên mạng cục bộ cho đến khi HTTPS được bật lại."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 기기에서의 전송은 HTTPS가 다시 켜질 때까지 로컬 네트워크에서 일반 HTTP를 사용합니다."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このデバイスでの転送では、HTTPS が再びオンになるまで、ローカル ネットワーク上のプレーン HTTP が使用されます。"
          }
        }
      }
    },
